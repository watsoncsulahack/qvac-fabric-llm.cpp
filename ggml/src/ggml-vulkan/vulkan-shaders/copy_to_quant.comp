// Generated by scripts/compute_tq_codebooks.py --dims 64 --bits 4 --c-code.
const float TBQ4_B[15] = float[15](
    -0.29180268220177841, -0.22582717916950065, -0.17683323251927041,
    -0.13565345351930996, -0.09885566129814261, -0.06466967310003119,
    -0.03198822095395431,  0.0,
     0.03198822095395431,  0.06466967310003119,  0.09885566129814261,
