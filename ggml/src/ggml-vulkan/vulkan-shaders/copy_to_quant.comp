uint tbq4_quantize_val(float val) {
    if (val < TBQ4_B[7]) {
        if (val < TBQ4_B[3]) {
            if (val < TBQ4_B[1]) { return val < TBQ4_B[0] ? 0u : 1u; }
            else                { return val < TBQ4_B[2] ? 2u : 3u; }
        } else {
            if (val < TBQ4_B[5]) { return val < TBQ4_B[4] ? 4u : 5u; }
            else                { return val < TBQ4_B[6] ? 6u : 7u; }
        }
    } else {
        if (val < TBQ4_B[11]) {
            if (val < TBQ4_B[9])  { return val < TBQ4_B[8]  ? 8u  : 9u;  }
            else                 { return val < TBQ4_B[10] ? 10u : 11u; }
        } else {
            if (val < TBQ4_B[13]) { return val < TBQ4_B[12] ? 12u : 13u; }
            else                 { return val < TBQ4_B[14] ? 14u : 15u; }
        }
    }
}

shared float tq4_sh_x[QUANT_K];
shared uint  tq4_sh_idx[QUANT_K];
#if defined(DATA_A_TBQ4_0) || defined(DATA_A_TBQ4_0_64)
shared float tq4_sh_proj[QUANT_K];
#endif

void quantize(uint dst_idx, uint src_idx)
{
    const uint BK = QUANT_K;
    const uint QS_BYTES = BK / 2u;
    const uint WG = 32u;
    const uint STRIDE = BK / WG;
    const uint lid = gl_LocalInvocationID.x;

    float local_sq = 0.0;
    [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
        uint j = lid + s * WG;
        float v = data_s[src_idx + j];
        tq4_sh_x[j] = v;
        local_sq += v * v;
    }
    float total_sq = tq_wg_add(local_sq);
    float norm = sqrt(total_sq);

    if (lid == 0u) {
        data_q[dst_idx].d = float16_t(norm);
    }

    // Uniform flag: all threads must agree on whether the norm is effectively zero.
    bool skip_quant = subgroupBroadcast(norm < 1e-15, 0u);

    if (skip_quant) {
        for (uint j = lid; j < QS_BYTES; j += WG) data_q[dst_idx].qs[j] = uint8_t(0);
#if defined(DATA_A_TBQ4_0) || defined(DATA_A_TBQ4_0_64)
        const uint QJL_BYTES = BK / 8u;
        for (uint j = lid; j < QJL_BYTES; j += WG) data_q[dst_idx].qjl[j] = uint8_t(0);
        if (lid == 0u) data_q[dst_idx].d_r = float16_t(0.0);
#endif
    } else {
        float inv_norm = 1.0 / norm;

        [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
            uint j = lid + s * WG;
            tq4_sh_idx[j] = tbq4_quantize_val(tq4_sh_x[j] * inv_norm);
        }
        barrier();

        // Pack nibble pairs: QS_BYTES = BK/2 (64 for BK=128, 32 for BK=64).
        for (uint b = lid; b < QS_BYTES; b += WG) {
            uint i0 = tq4_sh_idx[2u * b];
            uint i1 = tq4_sh_idx[2u * b + 1u];
            data_q[dst_idx].qs[b] = uint8_t(i0 | (i1 << 4u));
        }
    }

    // Only run norm correction and QJL if quantization was performed.
    if (!skip_quant) {
#if defined(TQ_NORM_CORRECTION)
        float local_xc = 0.0;
        float local_cc = 0.0;
        [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
            uint j = lid + s * WG;
            float cv = TBQ4_CB[tq4_sh_idx[j]];
            local_xc += tq4_sh_x[j] * cv;
            local_cc += cv * cv;
        }
        float dot_xc = tq_wg_add(local_xc);
        float dot_cc = tq_wg_add(local_cc);
        if (dot_cc > 1e-15) {
            norm = dot_xc / dot_cc;
        }
        if (lid == 0u) data_q[dst_idx].d = float16_t(norm);
#endif

#if defined(DATA_A_TBQ4_0) || defined(DATA_A_TBQ4_0_64)
    const uint QJL_BYTES = BK / 8u;

    float local_rsq = 0.0;
    [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
        uint j = lid + s * WG;
        float r = tq4_sh_x[j] - TBQ4_CB[tq4_sh_idx[j]] * norm;
        tq4_sh_proj[j] = r * qjl_get_sign(j);
        local_rsq += r * r;
    }
    float r_norm = sqrt(tq_wg_add(local_rsq));
    if (lid == 0u) data_q[dst_idx].d_r = float16_t(r_norm);

    // Uniform flag: all threads must agree on whether to run the FHT/QJL path.
    bool skip_fht = subgroupBroadcast(r_norm < 1e-15, 0u);

    if (skip_fht) {
        for (uint j = lid; j < QJL_BYTES; j += WG) data_q[dst_idx].qjl[j] = uint8_t(0);
    } else {
        for (uint h = 1u; h < BK; h <<= 1u) {
            for (uint bi = lid; bi < BK / 2u; bi += WG) {
                uint grp = bi / h;
                uint pos = bi % h;
                uint j = grp * (h << 1u) + pos;
                float a = tq4_sh_proj[j];
                float b = tq4_sh_proj[j + h];
                tq4_sh_proj[j]     = a + b;
                tq4_sh_proj[j + h] = a - b;
            }
            barrier();
        }

        // See tq3 path above for the NSG==1 vs NSG>1 split and the rationale
        // for staging through tq_sh_qjl[] before emitting bytes.
        const uint QJL_WORDS = (QJL_BYTES + 3u) / 4u;
        if (lid < QJL_WORDS) tq_sh_qjl[lid] = 0u;
        barrier();
        if (SG_SIZE >= TQ_WG) {
            [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
                uint j = lid + s * WG;
                uvec4 ballot = subgroupBallot(tq4_sh_proj[j] > 0.0);
                if (subgroupElect()) {
                    tq_sh_qjl[s] = ballot.x;
                }
            }
        } else {
            [[unroll]] for (uint s = 0u; s < STRIDE; s++) {
                uint j = lid + s * WG;
                if (tq4_sh_proj[j] > 0.0) {
                    atomicOr(tq_sh_qjl[j / 32u], 1u << (j % 32u));
                }
            }
        }
        barrier();
        if (lid < QJL_WORDS) {
            uint bits = tq_sh_qjl[lid];
            uint byte_off = lid * 4u;
            data_q[dst_idx].qjl[byte_off + 0u] = uint8_t(bits & 0xFFu);
            data_q[dst_idx].qjl[byte_off + 1u] = uint8_t((bits >> 8u) & 0xFFu);
            data_q[dst_idx].qjl[byte_off + 2u] = uint8_t((bits >> 16u) & 0xFFu);
            data_q[dst_idx].qjl[byte_off + 3u] = uint8_t((bits >> 24u) & 0xFFu);
        }
    }
#endif
    }
}
#endif

