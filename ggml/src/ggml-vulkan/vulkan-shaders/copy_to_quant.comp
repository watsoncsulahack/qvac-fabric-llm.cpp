);
#else
// Midpoints of TQ4_CODEBOOK_128.
// Generated by scripts/compute_tq_codebooks.py --dims 128 --bits 4 --c-code.
const float TBQ4_B[15] = float[15](
    -0.20921017409079767, -0.16127738300848593, -0.12600405430352871,
    -0.09651953803632701, -0.07026832190197044, -0.04593911875417284,
    -0.02271517840509901,  0.0,
     0.02271517840509901,  0.04593911875417284,  0.07026832190197044,
     0.09651953803632701,  0.12600405430352871,  0.16127738300848593,
